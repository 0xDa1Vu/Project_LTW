# Sao chép file này thành .env và chỉnh giá trị
APP_URL=http://localhost:8000
APP_ENV=local

# Database (khớp docker-compose.yml; service name là "db")
DB_HOST=db
DB_PORT=5432
DB_NAME=fashion_shop
DB_USER=shop
DB_PASS=shop_secret

# VNPay sandbox — lấy tại https://sandbox.vnpayment.vn/
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:8000/payment/vnpay/return
