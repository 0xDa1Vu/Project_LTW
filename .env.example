# Sao chép file này thành .env và chỉnh giá trị
APP_URL=http://localhost:8000
APP_ENV=local

# Database (MySQL/XAMPP mặc định: host 127.0.0.1, port 3306, user root không mật khẩu)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fashion_shop
DB_USER=root
DB_PASS=

# VNPay sandbox — lấy tại https://sandbox.vnpayment.vn/
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:8000/payment/vnpay/return

# SePay — chuyển khoản QR (https://sepay.vn). Cấu hình webhook trỏ về /payment/sepay/webhook
SEPAY_ACCOUNT_NUMBER=0123456789
SEPAY_BANK=MBBank
SEPAY_ACCOUNT_NAME=CUA HANG ATELIER
SEPAY_API_KEY=
SEPAY_PREFIX=DH
